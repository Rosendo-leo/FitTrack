<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FitTrack" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <!-- Splash exibida até o primeiro frame do Compose (core-splashscreen) -->
    <style name="Theme.FitTrack.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.FitTrack</item>
    </style>
</resources>
